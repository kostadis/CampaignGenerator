#!/bin/bash
# Stop the CampaignGenerator server started by ./start.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PID_FILE="$SCRIPT_DIR/server.pid"

if [ ! -f "$PID_FILE" ]; then
    echo "No PID file found — is the server running?"
    exit 1
fi

PID="$(cat "$PID_FILE")"

if ! kill -0 "$PID" 2>/dev/null; then
    echo "Process $PID not found. Cleaning up stale PID file."
    rm -f "$PID_FILE"
    exit 0
fi

echo "Stopping server (PID $PID)..."
kill "$PID"

for i in $(seq 1 10); do
    if ! kill -0 "$PID" 2>/dev/null; then
        rm -f "$PID_FILE"
        echo "Server stopped."
        exit 0
    fi
    sleep 0.5
done

echo "Server didn't stop cleanly — sending SIGKILL."
kill -9 "$PID" 2>/dev/null
rm -f "$PID_FILE"
echo "Server killed."
